# Layer Editor - Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL (used by docker-compose)
POSTGRES_DB=layer_editor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<set-a-strong-password>

# Backend - Windows profile database credentials
DB_USERNAME=postgres
DB_PASSWORD=<same-as-POSTGRES_PASSWORD>

# Backend - Default user password hash (BCrypt)
# Generate with: python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
# Or use an online BCrypt generator.
APP_DEFAULT_PASSWORD_HASH=$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lhWy

# Backend - HTTP Basic Auth credentials
APP_AUTH_USERNAME=editor
APP_AUTH_PASSWORD=<set-a-strong-password>

# Frontend - API auth (must match APP_AUTH_USERNAME/PASSWORD)
VITE_API_USERNAME=editor
VITE_API_PASSWORD=<same-as-APP_AUTH_PASSWORD>
